{
  "name": "speed-to-lead",
  "version": "1.0.0",
  "description": "Instant lead capture, scoring, routing & follow-up SaaS",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit && tsup src/index.ts --format esm --out-dir dist",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:seed": "tsx src/seed.ts",
    "lint": "eslint src --ext .ts",
    "client:dev": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "bull": "^4.12.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "bcryptjs": "^2.4.3",
    "bcryptjs": "^2.4.3",
    "resend": "^3.2.0",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.2",
    "prisma": "^5.15.0",
    "tsup": "^8.1.0",
    "tsx": "^4.15.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
